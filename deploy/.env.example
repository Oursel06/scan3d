# Copier vers /home/jordi/scan3d/shared/.env.local (chmod 600) et remplacer le token.
# Génération : openssl rand -hex 24
NODE_ENV=production
PORT=3017
HOST=127.0.0.1
SCAN3D_TOKEN=CHANGE_ME
SCAN3D_ORIGINS=https://scan3d.cube3d.fr
# Taille max d'un lot de points (defaut socket.io = 1 Mo, soit ~16 000 points :
# au-dela le serveur ferme la connexion sans erreur applicative).
SCAN3D_MAX_BATCH_MB=32
# Accepte les clients SANS token comme EMETTEURS uniquement (ils ne recoivent
# aucun scan). Requis tant que l'URL de l'app Android est figee dans le binaire.
SCAN3D_OPEN_INGEST=true
